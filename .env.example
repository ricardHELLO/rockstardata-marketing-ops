# ===========================================
# RockstarData Marketing Ops — Environment
# ===========================================
# Copy to .env and fill in real values

# Server
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# Database — local dev (matches docker-compose.dev.yml defaults)
DATABASE_URL=postgresql://rockstar:rockstar_dev@localhost:5433/marketing_ops

# Database — Docker Compose passwords (used in docker-compose.yml)
DB_PASSWORD=rockstar_dev
PAPERCLIP_DB_PASSWORD=paperclip_dev

# Internal auth (shared between Paperclip agents and this backend)
INTERNAL_API_KEY=change-me-to-a-random-string

# Paperclip AI
PAPERCLIP_AGENT_JWT_SECRET=       # Required: run `openssl rand -hex 32` to generate
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Anthropic (required for Paperclip claude_local adapter)
ANTHROPIC_API_KEY=                # sk-ant-...

# Pipedrive CRM
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_OWNER_ID=          # Ricard's Pipedrive user ID
# Custom field keys (find in Pipedrive Settings > Data fields)
PIPEDRIVE_FIELD_NUM_LOCATIONS=
PIPEDRIVE_FIELD_CONCEPT_TYPE=
PIPEDRIVE_FIELD_POS=
PIPEDRIVE_FIELD_SOURCE=
PIPEDRIVE_FIELD_CAMPAIGN=
PIPEDRIVE_FIELD_CARGO=
PIPEDRIVE_FIELD_LINKEDIN_URL=
PIPEDRIVE_PIPELINE_ID=       # Pipeline de restauración

# Slack
SLACK_BOT_TOKEN=             # xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APPROVAL_CHANNEL=      # Channel ID for #marketing-approvals

# Instantly (stub in V1)
INSTANTLY_API_KEY=

# Admin panel
ADMIN_PASSWORD=change-me
