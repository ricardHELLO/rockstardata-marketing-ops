{
  "name": "rockstardata-marketing-ops",
  "version": "1.0.0",
  "description": "Marketing operations backend for RockstarData — Paperclip AI agent orchestration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
